{
  "name": "@merrywhether/config-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "fix": "pnpm lint:es:fix && pnpm lint:md:fix",
    "lint": "pnpm lint:es && pnpm lint:md",
    "lint:es": "eslint .",
    "lint:es:fix": "pnpm lint:es --fix",
    "lint:md": "prettier '**/*.md' --check",
    "lint:md:fix": "prettier '**/*.md' --write",
    "pj": "node .projenrc.ts",
    "tc": "pnpm -r tc"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "devDependencies": {
    "@merrywhether/config": "workspace:*",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "eslint": "^10.2.1",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "projen": "^0.99.52",
    "react": "^19.2.5"
  },
  "packageManager": "pnpm@10.33.2"
}
