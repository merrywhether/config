{
  "name": "@merrywhether/config",
  "version": "6.3.1",
  "description": "Common config files for @merrywhether projects",
  "type": "module",
  "files": [
    "src/",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": "./src/projen/index.ts",
    "./eslint": "./src/eslint/index.ts",
    "./prettier": "./src/prettier.ts",
    "./package-type": "./src/projen/util/package-type.ts",
    "./ts-base": "./src/ts/base.json",
    "./ts-solid": "./src/ts/solid.json",
    "./ts-styled": "./src/ts/styled.json",
    "./ts-vue": "./src/ts/vue.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merrywhether/config.git"
  },
  "author": "merrywhether",
  "license": "MIT",
  "homepage": "https://github.com/merrywhether/config#readme",
  "scripts": {
    "clean": "rm -rf *.tsbuildinfo",
    "fix": "pnpm lint:es:fix && pnpm lint:md:fix",
    "lint": "pnpm lint:es && pnpm lint:md",
    "lint:es": "eslint .",
    "lint:es:fix": "pnpm lint:es --fix",
    "lint:md": "prettier '**/*.md' --check",
    "lint:md:fix": "prettier '**/*.md' --write",
    "pj": "node .projenrc.js",
    "tc": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.9.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "command-line-args": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "knitwork": "^1.3.0",
    "prettier": "^3.8.4",
    "projen": "^0.99.74",
    "semver": "^7.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "peerDependencies": {
    "@styled/typescript-styled-plugin": "^1.0.1"
  },
  "peerDependenciesMeta": {
    "@styled/typescript-styled-plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/semver": "^7.7.1"
  },
  "packageManager": "pnpm@11.7.0"
}
